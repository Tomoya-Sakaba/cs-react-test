{
  "description": "機器台帳 GemBox 印刷。Excelの {{excelKey}} と下記 source/dbColumn の対応を編集して運用する。",
  "templateFileName": "equipment_master.xlsx",
  "downloadFileNamePattern": "equipment_{equipment_code}_gembox.pdf",
  "scalars": [
    {
      "excelKey": "print_date",
      "source": "now",
      "format": "yyyy/MM/dd"
    },
    {
      "excelKey": "equipment_id",
      "source": "entity",
      "dbColumn": "equipment_id"
    },
    {
      "excelKey": "equipment_code",
      "source": "entity",
      "dbColumn": "equipment_code"
    },
    {
      "excelKey": "equipment_name",
      "source": "entity",
      "dbColumn": "equipment_name"
    },
    {
      "excelKey": "category",
      "source": "entity",
      "dbColumn": "category"
    },
    {
      "excelKey": "manufacturer",
      "source": "entity",
      "dbColumn": "manufacturer"
    },
    {
      "excelKey": "model",
      "source": "entity",
      "dbColumn": "model"
    },
    {
      "excelKey": "location",
      "source": "entity",
      "dbColumn": "location"
    },
    {
      "excelKey": "note",
      "source": "entity",
      "dbColumn": "note"
    },
    {
      "excelKey": "updated_at",
      "source": "entity",
      "dbColumn": "updated_at",
      "format": "yyyy/MM/dd HH:mm"
    }
  ],
  "tables": [
    {
      "tableKey": "history",
      "rows": [
        { "date": "2026/03/01", "action": "点検", "note": "外観確認" },
        { "date": "2026/03/20", "action": "交換", "note": "フィルタ交換" }
      ]
    }
  ]
}
