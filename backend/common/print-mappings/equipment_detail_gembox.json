{
  "description": "機器詳細＋部品テーブル(parts)＋関連機器(linked)＋履歴(history)。テンプレ equipment_master_detail.xlsx を BReportTemplateBasePath に置く。テーブルは上から history → parts → linked の順で行を配置（先行テーブル展開後に下へずれるため）。各 {{table:xxx}} と {{xxx.col}} は同一行。",
  "templateFileName": "equipment_master_detail.xlsx",
  "scalars": [
    { "excelKey": "print_date" },
    { "excelKey": "equipment_id", "dbColumn": "equipment_id" },
    { "excelKey": "equipment_code", "dbColumn": "equipment_code" },
    { "excelKey": "equipment_name", "dbColumn": "equipment_name" },
    { "excelKey": "category", "dbColumn": "category" },
    { "excelKey": "manufacturer", "dbColumn": "manufacturer" },
    { "excelKey": "model", "dbColumn": "model" },
    { "excelKey": "location", "dbColumn": "location" },
    { "excelKey": "note", "dbColumn": "note" },
    { "excelKey": "updated_at", "dbColumn": "updated_at" }
  ],
  "tables": [
    {
      "tableKey": "parts",
      "columns": [
        { "field": "part_code", "dbColumn": "part_code" },
        { "field": "qty", "dbColumn": "qty" },
        { "field": "note", "dbColumn": "note" }
      ]
    },
    {
      "tableKey": "linked",
      "columns": [
        { "field": "equipment_code", "dbColumn": "equipment_code" },
        { "field": "equipment_name", "dbColumn": "equipment_name" },
        { "field": "relation", "dbColumn": "relation" }
      ]
    }
  ]
}
